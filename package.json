{
  "name": "@atlasconsulting/bedita-sdk",
  "version": "3.3.2",
  "description": "A simple BEdita SDK based on axios",
  "repository": {
    "type": "git",
    "url": "https://github.com/atlasconsulting/bedita-sdk-js.git"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "./node_modules/.bin/tsc",
    "test": "NODE_OPTIONS='--loader ts-node/esm --no-warnings' TS_NODE_PROJECT='./tsconfig.test.json' mocha --require mock-local-storage --require tests/hooks.ts \"tests/**/*.test.ts\"",
    "coverage": "c8 npm run test",
    "lint": "eslint",
    "prepare": "husky"
  },
  "author": "Atlas <dev@atlasconsulting.it> (https://atlasconsulting.it)",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.0",
    "@commitlint/config-conventional": "^20.3.0",
    "@types/chai": "^4.3.4",
    "@types/mocha": "^10.0.1",
    "@types/node": "^24.10.4",
    "@typescript-eslint/eslint-plugin": "^8.52.0",
    "@typescript-eslint/parser": "^8.52.0",
    "c8": "^7.12.0",
    "chai": "^4.3.7",
    "eslint": "^9.39.2",
    "fetch-blob": "4.0.0",
    "husky": "^9.1.7",
    "mocha": "^10.2.0",
    "mock-local-storage": "^1.1.23",
    "source-map-support": "^0.5.21",
    "ts-node": "^10.9.1",
    "typescript": "^5.9.3"
  }
}
